<title>TaskCash237</title>
<style>
body {
  font-family: Arial, sans-serif;
  margin: 0;
  padding: 0;
  background: #f5f5f5;
  color: #333;
}
header {
  background: #ffcc00;
  padding: 20px;
  text-align: center;
}
.hero {
  padding: 40px 20px;
  text-align: center;
}
.btn {
  background: #008000;
  color: #ffffff;
  padding: 12px 25px;
  text-decoration: none;
  border-radius: 5px;
  display: inline-block;
  font-weight: bold;
